<?xml version='1.0' encoding='utf-8'?>
<widget id="safety.japan.call" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>Safety Japan Call</name>
    <description>نظام حماية متطور للمكالمات في اليابان</description>
    <author email="zakaria@example.com">Zakaria</author>
    
    <content src="index.html" />
    <access origin="*" />
    
    <!-- إعدادات لمنع الانهيار وتحسين التوافق -->
    <preference name="AndroidXEnabled" value="true" />
    <preference name="GradlePluginGoogleServicesEnabled" value="false" />
    <preference name="SplashScreen" value="none" />
    <preference name="android-minSdkVersion" value="24" />
    <preference name="android-targetSdkVersion" value="34" />

    <platform name="android">
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.READ_PHONE_STATE" />
            <uses-permission android:name="android.permission.READ_CALL_LOG" />
            <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
        </config-file>
        
        <!-- لضمان عدم تعارض الأيقونات أو السبلش القديم -->
        <edit-config target="AndroidManifest.xml" parent="/manifest/application" mode="merge">
            <application android:allowBackup="true" android:icon="@mipmap/ic_launcher" />
        </edit-config>
    </platform>
</widget>
